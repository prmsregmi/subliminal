# Copy to .env.secrets and fill in. `pnpm setup` pushes these into the Convex
# deployment as server-side env vars (the browser never sees them).
#
# ORANGESLICE_API_KEY is auto-read from ~/.config/orangeslice/config.json after
# you run `npx orangeslice login`, so you usually do NOT need to set it here.
# ORANGESLICE_API_KEY=osk_...

# Reddit "web app" credentials from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Must be a descriptive, unique UA or Reddit throttles you.
REDDIT_USER_AGENT=web:vibeseed:v0.1.0 (by /u/your_username)

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=
