# Copy to .env.secrets and fill in. `pnpm run secrets` pushes these into the
# Convex deployment as server-side env vars (the browser never sees them).
# Blank entries are skipped, so fill in only what you need.
#
# ORANGESLICE_API_KEY is auto-read from ~/.config/orangeslice/config.json after
# you run `npx orangeslice login`, so you usually do NOT need to set it here.
# ORANGESLICE_API_KEY=osk_...

# --- LLM inference (classification, drafts, BS-critic) ---
# Anthropic API key from https://console.anthropic.com (default provider).
ANTHROPIC_API_KEY=

# --- Embeddings + optional OpenAI inference ---
# OpenAI API key from https://platform.openai.com/api-keys
# Required for semantic RAG (subreddit-matching embeddings). To also use OpenAI
# for inference: npx convex env set LLM_PROVIDER openai
OPENAI_API_KEY=

# --- Subreddit discovery ---
# Apify token from https://console.apify.com/account/integrations
# PRIMARY discovery: keyword search within target subreddits.
APIFY_TOKEN=
# Optional: override the Apify actor (default harshmaur~reddit-scraper).
# APIFY_REDDIT_ACTOR=harshmaur~reddit-scraper

# Reddit "web app" credentials from https://www.reddit.com/prefs/apps
# Discovery FALLBACK when Apify is unset or fails.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Must be a descriptive, unique UA or Reddit throttles you.
REDDIT_USER_AGENT=web:subliminal:v0.1.0 (by /u/your_username)
